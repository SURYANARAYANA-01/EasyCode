{
  "name": "easycode-dev",
  "displayName": "EasyCode Dev",
  "description": "Generate beginner-friendly C++, Java, and Python programs instantly.",
  "version": "1.1.7",
  "publisher": "LazyDev",
  "icon": "images/Icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SURYANARAYANA-01/EasyCode.git"
  },
  "engines": {
    "vscode": "^1.117.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "easycodedev.generateProgram",
        "key": "ctrl+enter",
        "when": "editorTextFocus"
      }
    ],
    "commands": [
      {
        "command": "easycodedev.generateProgram",
        "title": "EasyCode Dev: Generate Program"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.117.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
